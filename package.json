{
  "name": "authjs-etoro",
  "version": "0.1.0",
  "description": "eToro SSO provider for Auth.js (@auth/core) — Login with eToro in ~5 lines of config",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "auth.js",
    "next-auth",
    "authjs",
    "etoro",
    "oauth",
    "oidc",
    "sso",
    "pkce",
    "authentication",
    "provider",
    "jwks"
  ],
  "author": "marianopa-tr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marianopa-tr/authjs-etoro.git"
  },
  "bugs": {
    "url": "https://github.com/marianopa-tr/authjs-etoro/issues"
  },
  "homepage": "https://github.com/marianopa-tr/authjs-etoro#readme",
  "peerDependencies": {
    "@auth/core": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "@auth/core": {
      "optional": false
    }
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@auth/core": "^0.37.0",
    "msw": "^2.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
